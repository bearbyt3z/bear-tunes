{
  "name": "bear-tunes",
  "version": "0.24.16",
  "description": "flac/mp3 converter & tagging tool based on Beatport tag style",
  "main": "./dist/main.js",
  "type": "module",
  "imports": {
    "#tools": "./dist/tools/index.js",
    "#converter": "./dist/converter/index.js",
    "#renamer": "./dist/renamer/index.js",
    "#tagger": "./dist/tagger/index.js",
    "#logger": "./dist/logger/index.js",
    "#shared-types": "./dist/shared-types.js",
    "#shared-types-schema": "./dist/shared-types.schema.js",
    "#shared-types-normalizer": "./dist/shared-types.normalizer.js"
  },
  "scripts": {
    "setup": "npx playwright install chromium",
    "typecheck": "npx tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf ./dist",
    "start": "node ./dist/main.js",
    "build": "npm run clean && npx tsc",
    "build-start": "npm run build && npm run start",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "author": "bearbyt3z",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "canvas": "^3.2.1",
    "file-type": "^22.0.1",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.58.2",
    "prompt-sync": "^4.2.0",
    "user-agents": "^1.1.669",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/user-agents": "^1.0.4",
    "ajv": "^8.18.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
