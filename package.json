{
  "name": "bear-tunes",
  "version": "0.21.2",
  "description": "flac/mp3 converter & tagging tool based on Beatport tag style",
  "main": "./dist/main.cjs",
  "type": "module",
  "imports": {
    "#tools": "./dist/tools/index.js",
    "#converter": "./dist/converter.js",
    "#renamer": "./dist/renamer.js",
    "#tagger": "./dist/tagger.js",
    "#logger": "./dist/logger.js",
    "#types": "./dist/types.js"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "setup": "npx playwright install chromium",
    "start": "node ./dist/main.cjs",
    "tsc": "npx tsc",
    "typecheck": "npx tsc --noEmit",
    "build-prod": "rm -rf ./dist && webpack --config webpack.config.prod.cjs",
    "build": "rm -rf ./dist && webpack --config webpack.config.dev.cjs",
    "build-start": "npm run build && npm run start",
    "build:native": "rm -rf ./dist && npx tsc",
    "start:native": "node ./dist/index.js",
    "build-start:native": "npm run build:native && npm run start:native"
  },
  "author": "bearbyt3z",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "canvas": "^3.2.1",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.58.2",
    "prompt-sync": "^4.2.0",
    "user-agents": "^1.1.669",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/user-agents": "^1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "ajv": "^8.18.0",
    "eslint": "^10.0.3",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "node-loader": "^2.1.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.1",
    "webpack-merge": "^6.0.1"
  }
}
